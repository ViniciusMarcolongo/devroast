{
  "name": "devroast",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "check": "biome check .",
    "format": "biome format --write .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:seed": "dotenv -e .env -- tsx src/db/seed.ts",
    "db:studio": "node scripts/run-drizzle-studio.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@number-flow/react": "^0.6.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "@trpc/tanstack-react-query": "^11.13.4",
    "client-only": "^0.0.1",
    "drizzle-orm": "^0.45.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@faker-js/faker": "^10.3.0",
    "@tailwindcss/postcss": "^4",
